# Nightly Test Suite
# Runs comprehensive slow tests every night at 2 AM UTC

name: Nightly Tests

on:
  # Run every night at 2 AM UTC
  schedule:
    - cron: '0 2 * * *'
  
  # Allow manual trigger
  workflow_dispatch:

jobs:
  nightly-full-suite:
    name: Full Test Suite (Nightly)
    runs-on: ubuntu-latest
    timeout-minutes: 120  # 2 hour timeout for comprehensive tests
    
    steps:
      - uses: actions/checkout@v4
      
      - name: Set up JDK 21
        uses: actions/setup-java@v4
        with:
          java-version: '21'
          distribution: 'temurin'
          cache: maven
      
      - name: Run All Tests (Fast, Cluster, Slow)
        run: |
          cd ${{ github.workspace }}
          # Override default exclusions to run ALL tests
          mvn -B test -pl crawler/core -DexcludedGroups=""
        continue-on-error: false
      
      - name: Upload Test Results
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: nightly-test-results
          path: |
            **/target/surefire-reports/
            **/target/failsafe-reports/
          retention-days: 30
      
      - name: Generate Test Report
        if: always()
        uses: dorny/test-reporter@v1
        with:
          name: Nightly Test Report
          path: '**/target/surefire-reports/*.xml'
          reporter: java-junit
          fail-on-error: true
      
      # Notify on failure
      - name: Notify on Failure
        if: failure()
        uses: actions/github-script@v7
        with:
          script: |
            github.rest.issues.create({
              owner: context.repo.owner,
              repo: context.repo.repo,
              title: '🔴 Nightly Tests Failed - ' + new Date().toDateString(),
              body: 'The nightly test suite has failed. Please check the [workflow run](' + context.serverUrl + '/' + context.repo.owner + '/' + context.repo.repo + '/actions/runs/' + context.runId + ') for details.',
              labels: ['test-failure', 'automated']
            })
