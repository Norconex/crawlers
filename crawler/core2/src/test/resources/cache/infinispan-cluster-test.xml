<?xml version="1.0" encoding="UTF-8"?>
<infinispan xmlns="urn:infinispan:config:15.0">
  <cache-container name="default" statistics="true" default-cache="default">
    <transport cluster="test-cluster"/>

    <distributed-cache-configuration
      name="default"
      mode="SYNC"
      owners="1"
      statistics="true"
    >
      <memory max-count="100"/>
      <expiration max-idle="30000"/>
      <state-transfer enabled="true" timeout="30000"/>
    </distributed-cache-configuration>
<!--     
    <distributed-cache-configuration name="*" configuration="default"/>
 -->

    <distributed-cache-configuration
      name="replicated-template"
      mode="SYNC"
      owners="2"
      statistics="true"
      configuration="default"
    />
    <distributed-cache-configuration name="*_replicated" configuration="replicated-template"/>

    <distributed-cache-configuration name="indexed-template" configuration="default">
      <indexing enabled="true" storage="local-heap">
        <indexed-entities>
          <indexed-entity>com.norconex.crawler.core2.cluster.impl.infinispan.CrawlEntryProtoAdapter</indexed-entity>
        </indexed-entities>
      </indexing>
    </distributed-cache-configuration>
    <distributed-cache-configuration name="*_indexed" configuration="indexed-template"/>

  </cache-container>

</infinispan>
