<infinispan xmlns="urn:infinispan:config:15.2"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="urn:infinispan:config:15.2 https://infinispan.org/schemas/infinispan-config-15.2.xsd">
            
  <!--
  ABOUT THIS FILE:
  Default Infinispan configuration used by the crawler to work out-of-the-box
  either standalone or in a cluster.  When running the crawler in a cluster,
  you are encouraged to use a shared database instead (e.g., JDBC) so storage
  persists beyond the crawler nodes lifespan.
  
  More details about Infinispan cache configuration:  
  https://infinispan.org/docs/stable/titles/configuring/configuring.html
   -->
            
  <cache-container name="default" default-cache="base-template">
  
    <transport cluster="${infinispan.cluster.name:cluster}" stack="crawler-udp" />
  
    <global-state enabled="true">
      <!-- 
        By default the persistent location is derived from the crawler working 
        directory.
        -->
      <persistent-location path="__DERIVED__/cache/infinispan"/>
    </global-state>
  
    <!-- 
      Cache configuration used as default if the crawler tries to load a 
      cache configuration not otherwise defined here.
      -->
    <distributed-cache-configuration 
      name="base-template" 
      mode="SYNC" 
      owners="2" 
      statistics="true"
    >
      <transaction
        mode="NON_XA"
        locking="PESSIMISTIC"
        transaction-manager-lookup="org.infinispan.transaction.lookup.GenericTransactionManagerLookup"
      />
      <persistence passivation="false">
        <file-store />
      </persistence>
    </distributed-cache-configuration>

    <distributed-cache-configuration name="indexed-template" configuration="base-template">
      <indexing enabled="true" storage="local-heap">
        <indexed-entities>
          <indexed-entity>com.norconex.crawler.core2.cluster.impl.infinispan.CrawlEntryProtoAdapter</indexed-entity>
        </indexed-entities>
      </indexing>
    </distributed-cache-configuration>

    <distributed-cache-configuration name="*_indexed" configuration="indexed-template"/>

    <!-- Cache used for sharing and also persisting arbitrary counters.  -->
    <distributed-cache 
      name="counter-cache"
      mode="SYNC"
      owners="2"
      statistics="true"
    >
      <persistence passivation="false">
        <file-store />
      </persistence>
    </distributed-cache>

  </cache-container>
  
  <jgroups>
    <stack name="crawler-udp">
      <!-- SHARED_LOOPBACK: Suitable for local testing or single-machine clusters -->
      <SHARED_LOOPBACK bind_addr="localhost"/>
      
      <!-- PING and MERGE3: Handle discovery and cluster merging -->
      <PING/>
      <MERGE3 max_interval="30000" min_interval="10000"/>
      
      <!-- FD_SOCK and FD_ALL3: Provide failure detection -->
      <FD_SOCK start_port="57800"/>
      <FD_ALL3 timeout="12000" interval="3000"/>
      
      <!-- VERIFY_SUSPECT: Confirms suspected node failures -->
      <VERIFY_SUSPECT timeout="1500"/>
      
      <!-- NAKACK2 and UNICAST3: Handle reliable multicast and unicast messaging -->
      <pbcast.NAKACK2 use_mcast_xmit="false"/>
      <UNICAST3/>
      
      <!-- STABLE: Ensures garbage collection of old messages -->
      <pbcast.STABLE desired_avg_gossip="50000"/>
      
      <!-- GMS: Manages group membership -->
      <pbcast.GMS print_local_addr="true" join_timeout="3000"/>
      
      <!-- UFC and MFC: Handle flow control -->
      <UFC max_credits="20000000" min_threshold="0.4"/>
      <MFC max_credits="20000000" min_threshold="0.4"/>
      
      <!-- FRAG2: Handles message fragmentation -->
      <FRAG2 frag_size="60000"/>
    
<!--
      <UDP/>
      <PING/>
      <MERGE3/>
      <VERIFY_SUSPECT/>
      <NAKACK2/>
      <UNICAST3/>
      <STABLE/>
      <GMS/>
      <UFC/>
      <MFC/>
      <FRAG2/>
-->
    </stack>
  </jgroups>  

  
</infinispan>
