<?xml version="1.0" encoding="UTF-8"?>
<infinispan xmlns="urn:infinispan:config:15.0">
  <cache-container name="default" statistics="true" default-cache="default">
    <transport cluster="test-cluster" stack="tcp"/>

    <!-- Persist container global state under the crawler workDir -->
    <global-state enabled="true">
      <persistent-location path="__DERIVED__/cache/infinispan"/>
    </global-state>

    <!-- === Cache Templates === -->

    <distributed-cache-configuration
      name="default"
      mode="SYNC"
      owners="2"
      statistics="true"
    >
      <encoding>
        <key media-type="application/x-protostream"/>
        <value media-type="application/x-protostream"/>
      </encoding>
      <transaction
        mode="NON_XA"
        locking="PESSIMISTIC"
        transaction-manager-lookup="org.infinispan.transaction.lookup.GenericTransactionManagerLookup"
      />
      <persistence passivation="false">
        <file-store />
      </persistence>
      <!-- Remove max-idle to avoid ISPN000651 with passivation=false -->
      <!-- Reduce test flakiness by avoiding rebalancing -->
      <state-transfer enabled="true"/>
      <!-- Allow reads during a split to prevent degraded mode failures in tests -->
      <partition-handling when-split="ALLOW_READS"/>
    </distributed-cache-configuration>

    <!-- Make indexed-template identical to default but without enabling indexing
         to avoid mass-index re-entrant cache opens during startup. -->
    <distributed-cache-configuration
      name="indexed-template"
      configuration="default"
    />

    <distributed-cache-configuration
      name="ephemeral-template"
      mode="SYNC"
      owners="2"
      statistics="true"
    >
      <expiration lifespan="-1"/>
      <persistence passivation="false"/>
      <partition-handling when-split="ALLOW_READS"/>
    </distributed-cache-configuration>

    <!-- === Cache Mappings === -->

    <distributed-cache-configuration name="*_indexed" configuration="indexed-template"/>
    <distributed-cache-configuration name="*_ephemeral" configuration="ephemeral-template"/>

    <!-- Explicit instances to avoid runtime definition races -->
    <distributed-cache name="admin"              configuration="default"/>
    <distributed-cache name="counters"           configuration="default"/>
    <distributed-cache name="crawler"            configuration="default"/>
    <distributed-cache name="crawlSession"       configuration="default"/>
    <distributed-cache name="crawlRun"           configuration="ephemeral-template"/>
    <distributed-cache name="crawlEventCounts"   configuration="default"/>
    <distributed-cache name="pipeCurrentStep"    configuration="default"/>
    <distributed-cache name="pipeWorkerStatuses" configuration="default"/>
    <!-- Ledger caches as ephemeral to avoid file-store lock contention -->
    <distributed-cache name="ledger_a"           configuration="ephemeral-template"/>
    <distributed-cache name="ledger_b"           configuration="ephemeral-template"/>
  </cache-container>
</infinispan>