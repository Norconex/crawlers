<infinispan xmlns="urn:infinispan:config:15.2"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="urn:infinispan:config:15.2 https://infinispan.org/schemas/infinispan-config-15.2.xsd">
            
  <!--
  TEST-SPECIFIC INFINISPAN CONFIGURATION
  This configuration is optimized for reliable, deterministic behavior in 
  integration tests, especially for multi-node cluster tests.
  
  Key differences from production config:
  - await-initial-transfer="true" to ensure nodes see all data before starting
  - Reduced timeouts for faster test execution
  - More aggressive consistency settings
   -->

  <cache-container name="default" default-cache="base-template">

    <!-- === GLOBAL SETTINGS =============================================== -->
  
    <transport cluster="${infinispan.cluster.name:cluster}" stack="tcp" />
  
    <global-state enabled="true">
      <persistent-location path="__WORKDIR__/cache/infinispan"/>
    </global-state>


    <!-- === CACHE TEMPLATES =============================================== -->
  
    <distributed-cache-configuration 
      name="base-template" 
      mode="SYNC" 
      owners="2" 
      statistics="true"
    >
      <encoding>
        <key media-type="application/x-protostream"/>
        <value media-type="application/x-protostream"/>
      </encoding>
      <transaction
        mode="NON_XA"
        locking="PESSIMISTIC"
        transaction-manager-lookup="org.infinispan.transaction.lookup.GenericTransactionManagerLookup"
      />
      <!-- CRITICAL FOR TESTS: Wait for state transfer to complete before operating -->
      <state-transfer enabled="true" timeout="60000" await-initial-transfer="true"/>
      <persistence passivation="false"/>
    </distributed-cache-configuration>

    <distributed-cache-configuration 
      name="indexed-template" 
      configuration="base-template"
    >
      <!-- Enable indexing for CrawlEntry using POJO annotations -->
      <indexing enabled="true" storage="local-heap">
        <indexed-entities>
          <indexed-entity>
            com.norconex.crawler.core.ledger.CrawlEntry
          </indexed-entity>
        </indexed-entities>
      </indexing>
      <encoding>
        <key media-type="application/x-protostream"/>
        <value media-type="application/x-java-object"/>
      </encoding>
      <!-- CRITICAL FOR TESTS: Wait for state transfer to complete -->
      <state-transfer enabled="true" timeout="60000" await-initial-transfer="true"/>
      <persistence passivation="false"/>
    </distributed-cache-configuration>

    <!-- For caches that don't survive a cluster run. -->
    <distributed-cache-configuration 
      name="ephemeral-template" 
      owners="2"
      mode="SYNC"
      statistics="true"
    >
      <expiration lifespan="-1"/>
      <state-transfer enabled="true" timeout="60000" await-initial-transfer="true"/>
      <persistence passivation="false"/>
    </distributed-cache-configuration>

    <replicated-cache-configuration 
      name="shutdown-safe-template" 
      mode="SYNC"
      statistics="true"
    >
      <encoding>
        <key media-type="application/x-protostream"/>
        <value media-type="application/x-protostream"/>
      </encoding>
      <transaction
        mode="NON_XA"
        locking="PESSIMISTIC"
        transaction-manager-lookup="org.infinispan.transaction.lookup.GenericTransactionManagerLookup"
      />
      <state-transfer enabled="true" timeout="60000" await-initial-transfer="true"/>
      <persistence passivation="false">
        <rocksdb-store xmlns="urn:infinispan:config:store:rocksdb:15.2"/>
      </persistence>
    </replicated-cache-configuration>

    <replicated-cache-configuration 
      name="ephemeral-replicated-template" 
      mode="SYNC"
      statistics="true">
      <encoding>
        <key media-type="application/x-protostream"/>
        <value media-type="application/x-protostream"/>
      </encoding>
      <transaction
        mode="NON_XA"
        locking="PESSIMISTIC"
        transaction-manager-lookup="org.infinispan.transaction.lookup.GenericTransactionManagerLookup"
      />
      <state-transfer enabled="true" timeout="60000" await-initial-transfer="true"/>
      <persistence passivation="false"/>
    </replicated-cache-configuration>

    <!-- === CACHE MAPPINGS ================================================ -->

    <distributed-cache-configuration name="*_indexed"   configuration="indexed-template"/>
    <distributed-cache-configuration name="*_ephemeral" configuration="ephemeral-template"/>

    <replicated-cache name="admin"              configuration="ephemeral-replicated-template"/>
    <replicated-cache name="pipeCurrentStep"    configuration="shutdown-safe-template"/>
    <replicated-cache name="pipeWorkerStatuses" configuration="shutdown-safe-template"/>
    
    <distributed-cache name="crawler"            configuration="base-template"/>
    <distributed-cache name="crawlSession"       configuration="base-template"/>
    <distributed-cache name="crawlRun"           configuration="ephemeral-template"/>
    <distributed-cache name="crawlEventCounts"   configuration="base-template"/>
    
    <distributed-cache name="ledger_a"           configuration="indexed-template">
      <persistence passivation="false">
        <rocksdb-store xmlns="urn:infinispan:config:store:rocksdb:15.2"/>
      </persistence>
    </distributed-cache>
    <distributed-cache name="ledger_b"           configuration="indexed-template">
      <persistence passivation="false">
        <rocksdb-store xmlns="urn:infinispan:config:store:rocksdb:15.2"/>
      </persistence>
    </distributed-cache>
    
    <distributed-cache 
      name="counters"
      mode="SYNC"
      owners="2"
      statistics="true"
    >
      <encoding>
        <key media-type="application/x-protostream"/>
        <value media-type="application/x-protostream"/>
      </encoding>
      <transaction
        mode="NON_XA"
        locking="PESSIMISTIC"
        transaction-manager-lookup="org.infinispan.transaction.lookup.GenericTransactionManagerLookup"
      />
      <state-transfer enabled="true" timeout="60000" await-initial-transfer="true"/>
      <persistence passivation="false">
        <rocksdb-store xmlns="urn:infinispan:config:store:rocksdb:15.2"/>
      </persistence>
    </distributed-cache>

  </cache-container>
  
</infinispan>
