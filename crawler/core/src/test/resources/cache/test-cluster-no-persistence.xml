<?xml version="1.0" encoding="UTF-8"?>
<infinispan xmlns="urn:infinispan:config:15.2"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="urn:infinispan:config:15.2 https://infinispan.org/schemas/infinispan-config-15.2.xsd">
  <!--
  FAST TEST CONFIGURATION
  Ultra-optimized for local testing with minimal cluster formation time.
  Uses SHARED_LOOPBACK for in-memory clustering (no network overhead).
  WARNING: DO NOT USE IN PRODUCTION
  - No network resilience
  - Optimized only for single-machine, multi-JVM testing
  - Fast but brittle
  -->
  <jgroups>
    <stack name="fast-test-loopback">
      <TCP bind_addr="127.0.0.1" bind_port="0" recv_buf_size="5M" send_buf_size="5M"
           thread_pool.enabled="true" thread_pool.keep_alive_time="10000"/>
      <FILE_PING location="${jgroups.ping.location:${java.io.tmpdir}/jgroups-ping}"/>
      <MERGE3 min_interval="500" max_interval="2000"/>
      <FD_SOCK2/>
      <FD_ALL3 timeout="5000" interval="1000"/>
      <VERIFY_SUSPECT timeout="500"/>
      <pbcast.NAKACK2 use_mcast_xmit="false" xmit_interval="200" discard_delivered_msgs="true"/>
      <UNICAST3 xmit_interval="200"/>
      <pbcast.STABLE desired_avg_gossip="2000" max_bytes="1M"/>
      <pbcast.GMS print_local_addr="true" join_timeout="5000" view_ack_collection_timeout="2000" leave_timeout="1000"/>
      <UFC max_credits="2M" min_threshold="0.4"/>
      <MFC max_credits="2M" min_threshold="0.4"/>
      <FRAG4 frag_size="60K"/>
    </stack>
  </jgroups>
  <cache-container name="default" default-cache="base-template">
    <transport cluster="${infinispan.cluster.name:cluster}" stack="fast-test-loopback" />
    <global-state enabled="true">
      <persistent-location path="__DERIVED__/cache/infinispan"/>
    </global-state>
    <!-- Cache templates (same as production for compatibility) -->
    <distributed-cache-configuration 
      name="base-template" 
      mode="SYNC" 
      owners="2" 
      statistics="true"
    >
      <encoding>
        <key media-type="application/x-protostream"/>
        <value media-type="application/x-protostream"/>
      </encoding>
      <transaction
        mode="NON_XA"
        locking="PESSIMISTIC"
        transaction-manager-lookup="org.infinispan.transaction.lookup.GenericTransactionManagerLookup"
      />
    </distributed-cache-configuration>
    <distributed-cache-configuration 
      name="indexed-template" 
      configuration="base-template"
    >
      <!-- Indexing disabled: Infinispan 15.2 doesn't support declarative 
           indexing with ProtoStream marshalling. Queries will work but use 
           full cache scans instead of indexes. -->
    </distributed-cache-configuration>
    <distributed-cache-configuration 
      name="ephemeral-template" 
      owners="2"
      mode="SYNC"
      statistics="true"
    >
      <expiration lifespan="-1"/>
    </distributed-cache-configuration>
    <!-- Cache mappings -->
    <distributed-cache-configuration name="*_indexed"   configuration="indexed-template"/>
    <distributed-cache-configuration name="*_ephemeral" configuration="ephemeral-template"/>
    <!-- Explicit cache instances -->
    <distributed-cache name="crawler"            configuration="base-template"/>
    <distributed-cache name="crawlSession"       configuration="base-template"/>
    <distributed-cache name="crawlRun"           configuration="ephemeral-template"/>
    <distributed-cache name="crawlEventCounts"   configuration="base-template"/>
    <distributed-cache name="pipeCurrentStep"    configuration="base-template"/>
    <distributed-cache name="pipeWorkerStatuses" configuration="base-template"/>
    <distributed-cache name="ledger_a"           configuration="indexed-template"/>
    <distributed-cache name="ledger_b"           configuration="indexed-template"/>
    <distributed-cache 
      name="counters"
      mode="SYNC"
      owners="2"
      statistics="true"
    />
  </cache-container>
</infinispan>
