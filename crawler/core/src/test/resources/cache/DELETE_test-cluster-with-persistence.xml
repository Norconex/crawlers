<?xml version="1.0" encoding="UTF-8"?>
<infinispan xmlns="urn:infinispan:config:15.2"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="urn:infinispan:config:15.2 https://infinispan.org/schemas/infinispan-config-15.2.xsd">
            
  <!--
  FAST TEST CONFIGURATION
  Ultra-optimized for local testing with minimal cluster formation time.
  Uses SHARED_LOOPBACK for in-memory clustering (no network overhead).

  NOTE ABOUT PERSISTENCE TEMPLATES
  ================================
  For tests we mirror the production strategy: generic templates
  (base-template, indexed-template, ephemeral-template) do not declare
  RocksDB stores directly. With global-state enabled and RocksDB on
  Windows, putting a store on a widely-used default template can lead
  to the same RocksDB directory being opened twice for caches like
  ledger_a, causing lock exceptions.

  Instead, tests rely on explicit RocksDB configuration on the
  concrete caches that need persistence (ledger_a, ledger_b, counters,
  and shutdown-safe caches), while the templates focus on topology,
  encoding, and indexing.

  WARNING: DO NOT USE IN PRODUCTION
  - No network resilience
  - Optimized only for single-machine, multi-JVM testing
  - Fast but brittle
  -->

  <jgroups>
    <stack name="fast-test-loopback">
      <!-- TCP with dynamic port allocation for multi-node testing on localhost -->
      <!-- IPv4 is forced via JVM arguments: -Djava.net.preferIPv4Stack=true -->
      <TCP bind_addr="127.0.0.1" 
           bind_port="0" 
           recv_buf_size="5M" 
           send_buf_size="5M"
           thread_pool.enabled="true"
           thread_pool.keep_alive_time="10000"/>
      
      <!-- FILE_PING for node discovery on localhost (shared file-based) -->
      <!-- Use cluster-specific location via system property, fallback to temp dir -->
      <FILE_PING location="${jgroups.ping.location:${java.io.tmpdir}/jgroups-ping}"/>
      
      <!-- Minimal protocols for fast local clustering -->
      <MERGE3 min_interval="500" max_interval="2000"/>
      <FD_SOCK2/>
      <FD_ALL3 timeout="5000" interval="1000"/>
      <VERIFY_SUSPECT timeout="500"/>
      <pbcast.NAKACK2 use_mcast_xmit="false" 
                      xmit_interval="200"
                      discard_delivered_msgs="true"/>
      <UNICAST3 xmit_interval="200"/>
      <pbcast.STABLE desired_avg_gossip="2000" max_bytes="1M"/>
      <pbcast.GMS print_local_addr="true" 
                  join_timeout="5000" 
                  view_ack_collection_timeout="2000"
                  leave_timeout="1000"/>
      <UFC max_credits="2M" min_threshold="0.4"/>
      <MFC max_credits="2M" min_threshold="0.4"/>
      <FRAG4 frag_size="60K"/>
    </stack>
  </jgroups>

  <cache-container name="default" default-cache="base-template">
    <transport cluster="${infinispan.cluster.name:cluster}" stack="fast-test-loopback" />
  
    <global-state enabled="true">
      <persistent-location path="__WORKDIR__/cache/infinispan"/>
    </global-state>

    <!-- Cache templates -->
    
    <!-- DISTRIBUTED templates (owners=2) for regular data - storage efficient -->
    <distributed-cache-configuration 
      name="base-template" 
      mode="SYNC"
      owners="2"
      statistics="true">
      <encoding>
        <key media-type="application/x-protostream"/>
        <value media-type="application/x-protostream"/>
      </encoding>
      <transaction
        mode="NON_XA"
        locking="PESSIMISTIC"
        transaction-manager-lookup=
          "org.infinispan.transaction.lookup.GenericTransactionManagerLookup"/>
      <state-transfer enabled="true" timeout="30000"
                      await-initial-transfer="false"/>
      <!-- IMPORTANT: Do not configure RocksDB here. Template-level
           persistence, when combined with global state, can cause
           Infinispan to attempt a second RocksDB open for caches
           like ledger_a within the same JVM on Windows. Concrete
           caches opt into RocksDB explicitly below. -->
      <persistence passivation="false"/>
    </distributed-cache-configuration>

    <distributed-cache-configuration 
      name="indexed-template" 
      configuration="base-template">
      <!-- Enable indexing for CrawlEntry using POJO annotations -->
      <indexing enabled="true" storage="local-heap">
        <indexed-entities>
          <indexed-entity>
            com.norconex.crawler.core.ledger.CrawlEntry
          </indexed-entity>
        </indexed-entities>
      </indexing>
      <!-- Encode values as Java objects so Hibernate Search POJO
           annotations apply -->
      <encoding>
        <key media-type="application/x-protostream"/>
        <value media-type="application/x-java-object"/>
      </encoding>
      <state-transfer enabled="true" timeout="30000"
                      await-initial-transfer="false"/>
      <!-- IMPORTANT: As with base-template, avoid RocksDB here.
           Indexed caches that require persistence define RocksDB
           at the concrete cache level (ledger_a, ledger_b). -->
      <persistence passivation="false"/>
    </distributed-cache-configuration>

    <distributed-cache-configuration 
      name="ephemeral-template" 
      mode="SYNC"
      owners="2"
      statistics="true">
      <expiration lifespan="-1"/>
      <state-transfer enabled="true" timeout="30000"
                      await-initial-transfer="false"/>
      <persistence passivation="false"/>
    </distributed-cache-configuration>
    
    <!-- REPLICATED template for shutdown-critical caches - full replication -->
    <!-- Used by: pipeCurrentStep, pipeWorkerStatuses -->
    <!-- Guarantees coordinator can read worker status even after workers exit -->
    <replicated-cache-configuration 
      name="shutdown-safe-template" 
      mode="SYNC"
      statistics="true">
      <encoding>
        <key media-type="application/x-protostream"/>
        <value media-type="application/x-protostream"/>
      </encoding>
      <state-transfer enabled="true" timeout="30000"
                      await-initial-transfer="false"/>
      <persistence passivation="false">
        <rocksdb-store xmlns=
          "urn:infinispan:config:store:rocksdb:15.2"/>
      </persistence>
    </replicated-cache-configuration>

    <!-- New: replicated, non-persistent template for admin (ephemeral control-plane) -->
    <replicated-cache-configuration
      name="ephemeral-replicated-template"
      mode="SYNC"
      statistics="true">
      <encoding>
        <key media-type="application/x-protostream"/>
        <value media-type="application/x-protostream"/>
      </encoding>
      <state-transfer enabled="true" timeout="30000"
                      await-initial-transfer="false"/>
      <persistence passivation="false"/>
    </replicated-cache-configuration>

    <!-- Cache mappings -->
    <distributed-cache-configuration name="*_indexed"
                                     configuration="indexed-template"/>
    <distributed-cache-configuration name="*_ephemeral"
                                     configuration="ephemeral-template"/>

    <!-- CRITICAL: Shutdown-safe caches -->
    <replicated-cache name="admin"
                      configuration="ephemeral-replicated-template"/>
    <replicated-cache name="pipeCurrentStep"
                      configuration="shutdown-safe-template"/>
    <replicated-cache name="pipeWorkerStatuses"
                      configuration="shutdown-safe-template"/>

    <!-- Regular caches (distributed with owners=2) -->
    <distributed-cache name="crawler"          configuration="base-template"/>
    <distributed-cache name="crawlSession"     configuration="base-template"/>
    <distributed-cache name="crawlRun"         configuration="ephemeral-template"/>
    <distributed-cache name="crawlEventCounts" configuration="base-template"/>

    <!-- Explicitly persistent caches with RocksDB -->
    <distributed-cache name="ledger_a"
                      configuration="indexed-template">
      <persistence passivation="false">
        <rocksdb-store xmlns=
          "urn:infinispan:config:store:rocksdb:15.2"/>
      </persistence>
    </distributed-cache>

    <distributed-cache name="ledger_b"
                      configuration="indexed-template">
      <persistence passivation="false">
        <rocksdb-store xmlns=
          "urn:infinispan:config:store:rocksdb:15.2"/>
      </persistence>
    </distributed-cache>

    <distributed-cache name="counters"
                      mode="SYNC"
                      owners="2"
                      statistics="true">
      <persistence passivation="false">
        <rocksdb-store xmlns=
          "urn:infinispan:config:store:rocksdb:15.2"/>
      </persistence>
    </distributed-cache>
  </cache-container>
</infinispan>
