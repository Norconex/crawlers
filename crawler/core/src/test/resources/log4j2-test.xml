<!DOCTYPE xml>
<Configuration status="WARN" name="Norconex Crawler Core">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss} [%t] %-5level %c{2} - %msg%n"/>
    </Console>
  </Appenders>
  <Loggers>

    <!-- Suppress Hazelcast logo -->
    <Logger name="com.hazelcast.system.logo" level="OFF" additivity="false"/>

    <Logger name="com.norconex.crawler.core.cmd.crawl.pipeline.process.BatchDispatcher" level="TRACE" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="com.norconex.crawler.core.ledger.CrawlEntryLedger" level="TRACE" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="liquibase" level="WARN" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="ImporterEvent" level="WARN" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="CommitterServiceEvent" level="WARN" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="com.norconex.crawler.core" level="DEBUG" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="com.norconex.crawler.core.cli" level="DEBUG" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="com.norconex.crawler.core.junit" level="DEBUG" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="com.norconex.crawler.core.cluster.pipeline.PipelineTest" level="DEBUG" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="com.norconex.importer" level="INFO" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="com.norconex.commons.lang.event" level="INFO" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="com.norconex.commons.lang.bean" level="INFO" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="com.norconex.commons.lang.config" level="INFO" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="org.infinispan" level="WARN" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="org.jgroups" level="INFO" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="org.hibernate.validator.internal.util.Version" level="WARN" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="org.hibernate.search" level="INFO" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="org.hibernate.search.backend.lucene.impl.LuceneBackendFactory" level="ERROR" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="org.apache" level="WARN" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="com.zaxxer" level="INFO" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Root level="INFO">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>
