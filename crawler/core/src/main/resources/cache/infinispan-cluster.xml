<infinispan xmlns="urn:infinispan:config:15.2"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="urn:infinispan:config:15.2 https://infinispan.org/schemas/infinispan-config-15.2.xsd">
            
  <!--
  ABOUT THIS FILE:
  Default Infinispan configuration used by the crawler to work out-of-the-box
  either standalone or in a cluster.  When running the crawler in a cluster,
  you are encouraged to configure Infinispan to use a shared database instead 
  (e.g., JDBC) so storage persists beyond the crawler nodes life span.

  NOTE ABOUT PERSISTENCE TEMPLATES
  --------------------------------
  We intentionally avoid declaring RocksDB stores on the generic
  distributed templates (base-template, indexed-template).
  
  With global-state enabled and RocksDB on Windows, having a
  persistence store on a widely-used default template can cause
  certain caches (e.g., ledger_a) to be opened twice internally via
  different initialization paths, which results in spurious
  RocksDB "LOCK" errors.
  
  Instead, concrete caches that genuinely require persistence (such as
  ledger_a, ledger_b, and counters) declare their RocksDB stores
  explicitly. This keeps template reuse for topology/encoding while
  avoiding double-opens of the same RocksDB directory.
  
  More details about Infinispan cache configuration:  
  https://infinispan.org/docs/stable/titles/configuring/configuring.html
   -->

  <cache-container name="default" default-cache="base-template">

    <!-- === GLOBAL SETTINGS =============================================== -->
  
    <transport cluster="${infinispan.cluster.name:cluster}" stack="tcp" />
  
    <global-state enabled="true">
      <!-- 
        By default the persistent location is derived from the crawler working 
        directory.
        -->
      <persistent-location path="__WORKDIR__/cache/infinispan"/>
    </global-state>


    <!-- === CACHE TEMPLATES =============================================== -->
  
    <!-- 
      Cache configuration used as default if the crawler tries to load a 
      cache configuration not otherwise defined here.
      -->
    <distributed-cache-configuration 
      name="base-template" 
      mode="SYNC" 
      owners="2" 
      statistics="true"
    >
      <encoding>
        <key media-type="application/x-protostream"/>
        <value media-type="application/x-protostream"/>
      </encoding>
      <transaction
        mode="NON_XA"
        locking="PESSIMISTIC"
        transaction-manager-lookup="org.infinispan.transaction.lookup.GenericTransactionManagerLookup"
      />
      <!-- Configure state transfer to be non-blocking to allow quick cluster joins -->
      <state-transfer enabled="true" timeout="30000" await-initial-transfer="false"/>
      <!-- NOTE: Do NOT configure a RocksDB store here. Using a global
           persistence store on the default template, combined with
           global state, can cause Infinispan to open RocksDB twice
           for certain caches (e.g., ledger_a) within the same JVM
           on Windows. Per-cache persistence is defined instead on
           each concrete cache below. -->
      <persistence passivation="false"/>
    </distributed-cache-configuration>

    <distributed-cache-configuration 
      name="indexed-template" 
      configuration="base-template"
    >
      <!-- Enable indexing for CrawlEntry using POJO annotations -->
      <indexing enabled="true" storage="local-heap">
        <indexed-entities>
          <indexed-entity>
            com.norconex.crawler.core.ledger.CrawlEntry
          </indexed-entity>
        </indexed-entities>
      </indexing>
      <!-- Encode values as Java objects so Hibernate Search POJO annotations apply -->
      <encoding>
        <key media-type="application/x-protostream"/>
        <value media-type="application/x-java-object"/>
      </encoding>
      <!-- Configure state transfer to be non-blocking -->
      <state-transfer enabled="true" timeout="30000" await-initial-transfer="false"/>
      <!-- NOTE: As with base-template, avoid declaring RocksDB here to
           prevent template-level double-open interactions with
           global state. Persistence for indexed caches is defined on
           the concrete caches (e.g., ledger_a, ledger_b) instead. -->
      <persistence passivation="false"/>
    </distributed-cache-configuration>



    <!-- For caches that don't survive a cluster run. -->
    <distributed-cache-configuration 
      name="ephemeral-template" 
      owners="2"
      mode="SYNC"
      statistics="true"
    >
      <expiration lifespan="-1"/>
      <!-- Configure state transfer to be non-blocking -->
      <state-transfer enabled="true" timeout="30000" await-initial-transfer="false"/>
      <persistence passivation="false"/>
    </distributed-cache-configuration>

    <!-- 
      REPLICATED template for shutdown-critical data.
      Fully replicates to ALL nodes to ensure coordinator can always read data 
      even during coordinated shutdown when multiple workers exit simultaneously.
      
      Use cases:
      - Worker pipeline status (pipeWorkerStatuses)
      - Coordinator state (pipeCurrentStep)
      - Stop signals (admin)
      
      Trade-off: Higher storage and network overhead during writes,
      but guarantees data availability during cluster-wide shutdown.
    -->
    <replicated-cache-configuration 
      name="shutdown-safe-template" 
      mode="SYNC"
      statistics="true"
    >
      <encoding>
        <key media-type="application/x-protostream"/>
        <value media-type="application/x-protostream"/>
      </encoding>
      <transaction
        mode="NON_XA"
        locking="PESSIMISTIC"
        transaction-manager-lookup="org.infinispan.transaction.lookup.GenericTransactionManagerLookup"
      />
      <state-transfer enabled="true" timeout="30000" await-initial-transfer="false"/>
      <persistence passivation="false">
        <rocksdb-store xmlns="urn:infinispan:config:store:rocksdb:15.2"/>
      </persistence>
    </replicated-cache-configuration>

    <!-- New: replicated, non-persistent template for admin control-plane -->
    <replicated-cache-configuration 
      name="ephemeral-replicated-template" 
      mode="SYNC"
      statistics="true">
      <encoding>
        <key media-type="application/x-protostream"/>
        <value media-type="application/x-protostream"/>
      </encoding>
      <transaction
        mode="NON_XA"
        locking="PESSIMISTIC"
        transaction-manager-lookup="org.infinispan.transaction.lookup.GenericTransactionManagerLookup"
      />
      <state-transfer enabled="true" timeout="30000" await-initial-transfer="false"/>
      <persistence passivation="false"/>
    </replicated-cache-configuration>

    <!-- === CACHE MAPPINGS ================================================ -->

    <distributed-cache-configuration name="*_indexed"   configuration="indexed-template"/>
    <distributed-cache-configuration name="*_ephemeral" configuration="ephemeral-template"/>

    <!-- CRITICAL: Shutdown-safe caches (fully replicated to ALL nodes) -->
    <!-- admin: replicated, in-memory-only stop signalling cache -->
    <replicated-cache name="admin"              configuration="ephemeral-replicated-template"/>
    <replicated-cache name="pipeCurrentStep"    configuration="shutdown-safe-template"/>
    <replicated-cache name="pipeWorkerStatuses" configuration="shutdown-safe-template"/>
    
    <!-- Regular caches (distributed with owners=2 for storage efficiency) -->
    <distributed-cache name="crawler"            configuration="base-template"/>
    <distributed-cache name="crawlSession"       configuration="base-template"/>
    <distributed-cache name="crawlRun"           configuration="ephemeral-template"/>
    <distributed-cache name="crawlEventCounts"   configuration="base-template"/>
    <!-- Explicitly configure RocksDB persistence only on concrete ledger
         and counters caches to avoid template-level double-open issues.
         This keeps persistence for these caches while avoiding the
         problematic combination of global-state-managed defaults and
         RocksDB-backed templates. -->
    <distributed-cache name="ledger_a"           configuration="indexed-template">
      <persistence passivation="false">
        <rocksdb-store xmlns="urn:infinispan:config:store:rocksdb:15.2"/>
      </persistence>
    </distributed-cache>
    <distributed-cache name="ledger_b"           configuration="indexed-template">
      <persistence passivation="false">
        <rocksdb-store xmlns="urn:infinispan:config:store:rocksdb:15.2"/>
      </persistence>
    </distributed-cache>
    <!-- Cache used for sharing and also persisting arbitrary counters.  -->
    <distributed-cache 
      name="counters"
      mode="SYNC"
      owners="2"
      statistics="true"
    >
      <persistence passivation="false">
        <rocksdb-store xmlns="urn:infinispan:config:store:rocksdb:15.2"/>
      </persistence>
    </distributed-cache>

  </cache-container>
  
</infinispan>
