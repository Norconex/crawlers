      "patterns": [
        "^(the )?(new |revised |modified )?bsd( 3 clause)?( licen[sc]e( 3)?)?$",
        "^(the )?bsd 3 clause license( bsd3)?$",
        "^bsd 3 clause bsd 3 clause new or revised license$",
        "^eclipse distribution license version 1$",
        "^edl 1$",
        "^bsd 3 clause$",
        "^(the )?new bsd license$",
        "^bsd license 3$"
