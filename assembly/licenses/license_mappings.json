      "patterns": ["^0bsd$", "^bsd zero clause license$"]
    },
    {
      "spdx_id": "Apache-2.0",
      "full_name": "Apache License 2.0",
      "patterns": [
        "^(the )?apache( software)?( license)?( version)? ?2$",
        "^asf 2$",
        "^asl 2$",
        "^apache 2$",
        "^apache license$",
        "^apache software licenses$",
        "^apache 2 license$"
      ]
    },
    {
